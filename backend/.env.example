# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB — paste YOUR connection string here (then copy this file to .env)
#
# Local MongoDB (same machine):
# MONGO_URI=mongodb://127.0.0.1:27017/gymflow
#
# Local with username/password:
# MONGO_URI=mongodb://USERNAME:PASSWORD@127.0.0.1:27017/gymflow?authSource=admin
#
# MongoDB Atlas (cloud) — from Atlas → Connect → Drivers, copy the URI and:
#   - Replace <password> with your DB user password (URL-encode special chars: @ → %40)
#   - Pick a database name at the end (e.g. gymflow) instead of myFirstDatabase
# Example:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/gymflow?retryWrites=true&w=majority
#
MONGO_URI=mongodb://127.0.0.1:27017/gymflow

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Email (optional — renewal reminders & campaigns use SMTP when set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary (optional — image upload falls back to local URLs if missing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (optional — mock mode if missing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Firebase Admin (optional — push skipped if missing)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

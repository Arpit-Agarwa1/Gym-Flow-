# Local dev: matches vite.config.js proxy (see `/api` → backend).
VITE_API_URL=http://localhost:5000/api

# Vercel (Dashboard → Settings → Environment Variables): set for Production AND Preview.
# Must be the public API base path including /api (no trailing slash). Rebuild after changing.
# Example: VITE_API_URL=https://gym-flow-sqdr.onrender.com/api

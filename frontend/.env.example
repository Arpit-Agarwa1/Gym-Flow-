# Local dev: matches vite.config.js proxy (see `/api` → backend).
VITE_API_URL=http://localhost:5000/api

# Vercel (Dashboard → Settings → Environment Variables): set for Production AND Preview.
# MUST end with /api (this app’s Express routes live under /api). No trailing slash after /api.
# Wrong: https://your-app.onrender.com  → requests hit /leads and 404.
# Right: https://your-app.onrender.com/api
# Example: VITE_API_URL=https://gym-flow-sqdr.onrender.com/api
